rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null && request.auth.token.email != null;
    }

    function participant(conversationId) {
      return signedIn()
        && request.auth.token.email in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantEmails;
    }

    match /users/{userId} {
      allow read, create, update: if signedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /conversations/{conversationId} {
      allow read: if signedIn()
        && request.auth.token.email in resource.data.participantEmails;
      allow create: if signedIn()
        && request.auth.token.email in request.resource.data.participantEmails;
      allow update: if signedIn()
        && request.auth.token.email in resource.data.participantEmails
        && request.resource.data.participantEmails == resource.data.participantEmails;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if participant(conversationId);
        allow create: if participant(conversationId)
          && request.resource.data.senderEmail == request.auth.token.email;
        allow update, delete: if false;
      }
    }
  }
}
